  "connections": {
    "a5213d25-14b5-4a3a-920b-b2a4f7c47144": {
      "id": "a5213d25-14b5-4a3a-920b-b2a4f7c47144",
      "name": "Ziggo",
      "ref": "#imap",
      "isGlobal": false,
      "settings": {
        "name": "Ziggo",
        "server": "=$property[\"Mail.Ziggo.IMAP_Mail_Server\"]",
        "authType": "Basic",
