          {
            "id": "EMSSendMessage",
            "name": "EMSSendMessage",
            "description": "This activity sends message to the specified EMS destination",
            "activity": {
              "ref": "#sendmessage",
              "settings": {
                "connection": "conn://43a40201-5d92-40a1-a884-157031567b36",
                "destinationType": "Queue",
                "settingDestination": "bw5.test",
                "deliveryDelay": 0
              },
              "input": {
                "message": "=$flow.body.inputMessage",
                "destination": ""
